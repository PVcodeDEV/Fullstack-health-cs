{
  "name": "clinica-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "ERP Clínico - Tailwind CSS build chain",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ../backend/src/main/resources/static/css/output.css --minify",
    "watch": "tailwindcss -i ./src/input.css -o ../backend/src/main/resources/static/css/output.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
